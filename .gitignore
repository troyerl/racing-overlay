# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
tracks-html/

# Local pip vendor tree (tool deps installed with --target)
.pip_deps/

# PyInstaller build output
dist/
build/
*.spec

# Secrets / local env (e.g. GRIDGLANCE_MONGODB_URI)
.env
.env.*
!.env.example

# Runtime / user-generated state
overlay_config.json
overlay_layout.json
stderr.txt
*.log

# OS / editor
.DS_Store
.idea/
.vscode/
.cursor/

# Fetched track library (keep only the bundled demo track)
/tracks/*
!/tracks/_demo.json
